---
// src/components/Header.astro
// Reemplaza el header de Starlight con selector de plugins integrado
import Default from '@astrojs/starlight/components/Header.astro';
import { plugins } from '../data/plugins.js';

const currentPath = Astro.url.pathname;

// Detectar qué plugin está activo basado en la URL
function getActivePlugin(path) {
  for (const plugin of plugins) {
    if (path.startsWith(`/${plugin.id}/`) || path === `/${plugin.id}`) {
      return plugin.id;
    }
  }
  return null;
}

const activePlugin = getActivePlugin(currentPath);
---

<Default {...Astro.props}>
  <div slot="right-sidebar-before" style="display:none"></div>
</Default>

<!-- Plugin switcher — aparece bajo el header nativo de Starlight -->
<div class="plugin-switcher-bar">
  <div class="plugin-switcher-inner">
    <a href="/" class="switcher-home" title="Back to home">
      <i class="bi bi-house-fill"></i>
    </a>
    <div class="switcher-divider"></div>
    <div class="switcher-label">Plugin:</div>
    <div class="plugin-switcher-tabs">
      {plugins.map((plugin) => (
        <a
          href={`/${plugin.id}/introduction`}
          class={`switcher-tab ${activePlugin === plugin.id ? 'active' : ''}`}
        >
          <img src={plugin.logo} alt={plugin.name} class="switcher-logo" onerror="this.style.display='none'" />
          <span>{plugin.name}</span>
          {plugin.featured && <span class="switcher-badge">{plugin.featuredLabel}</span>}
        </a>
      ))}
    </div>
  </div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
.plugin-switcher-bar {
  background: var(--sl-color-bg-nav);
  border-bottom: 1px solid var(--sl-color-gray-6);
  padding: 0 1rem;
  position: sticky;
  top: var(--sl-nav-height, 3.5rem);
  z-index: 19;
  backdrop-filter: blur(12px);
}
.plugin-switcher-inner {
  max-width: 1400px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  gap: 0.75rem;
  height: 40px;
  overflow-x: auto;
  scrollbar-width: none;
}
.plugin-switcher-inner::-webkit-scrollbar { display: none; }

.switcher-home {
  color: var(--sl-color-gray-3);
  text-decoration: none;
  font-size: 15px;
  display: flex;
  align-items: center;
  padding: 4px 6px;
  border-radius: 6px;
  transition: all 0.15s;
  flex-shrink: 0;
}
.switcher-home:hover { color: var(--sl-color-accent); background: var(--sl-color-gray-6); }

.switcher-divider {
  width: 1px;
  height: 18px;
  background: var(--sl-color-gray-5);
  flex-shrink: 0;
}
.switcher-label {
  font-size: 0.72rem;
  font-weight: 600;
  color: var(--sl-color-gray-3);
  text-transform: uppercase;
  letter-spacing: 0.8px;
  flex-shrink: 0;
}
.plugin-switcher-tabs {
  display: flex;
  gap: 0.25rem;
  align-items: center;
}
.switcher-tab {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 4px 12px;
  border-radius: 6px;
  font-size: 0.78rem;
  font-weight: 500;
  text-decoration: none;
  color: var(--sl-color-gray-2);
  transition: all 0.15s;
  white-space: nowrap;
  border: 1px solid transparent;
}
.switcher-tab:hover {
  background: var(--sl-color-gray-6);
  color: var(--sl-color-white);
}
.switcher-tab.active {
  background: color-mix(in srgb, var(--sl-color-accent) 12%, transparent);
  border-color: color-mix(in srgb, var(--sl-color-accent) 30%, transparent);
  color: var(--sl-color-accent);
}
.switcher-logo {
  width: 16px;
  height: 16px;
  object-fit: contain;
  border-radius: 3px;
}
.switcher-badge {
  font-size: 0.58rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  background: var(--sl-color-accent);
  color: #000;
  padding: 1px 5px;
  border-radius: 100px;
  line-height: 1.4;
}
</style>
