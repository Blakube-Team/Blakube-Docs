<script>
function copyDiscord() {
  navigator.clipboard.writeText('blakubedesign').then(() => {
    const el = document.getElementById('cf');
    el.classList.add('show');
    setTimeout(() => el.classList.remove('show'), 2000);
  });
}
function copyUser(btn, user) {
  navigator.clipboard.writeText(user).then(() => {
    btn.style.color = '#00d4ff'; btn.style.borderColor = '#00d4ff';
    setTimeout(() => { btn.style.color = ''; btn.style.borderColor = ''; }, 1500);
  });
}
function openLegal(page) {
  document.getElementById('page-' + page).classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeLegal() {
  document.querySelectorAll('.legal-page').forEach(p => p.classList.remove('open'));
  document.body.style.overflow = '';
}
