          <a href="/bk-tops/intro/introduction/" class="plugin-doc-link">Docs →</a>
        </div>
      </div>
    </div>
    <div class="plugin-card">
      <div class="plugin-banner" style="background-image:url('/brand/bk-gradients-banner.jpg');">
        <div class="plugin-banner-line"></div>
      </div>
      <div class="plugin-body">
        <div class="plugin-header">
          <div class="plugin-logo">🎨</div>
          <div class="plugin-price">
            <div class="plugin-price-label">Price</div>
            <div class="plugin-price-val">$7.99</div>
          </div>
        </div>
        <div class="plugin-name">BK-Gradients</div>
        <div class="plugin-desc">Full visual identity system. HEX gradient prefixes, nicks, suffixes and tags with 100% YAML-driven GUIs and live reload.</div>
        <div class="plugin-tags">
          <span class="tag">Cosmetics</span><span class="tag">MiniMessage</span><span class="tag">SQLite</span><span class="tag">MySQL</span><span class="tag">Paper 1.21+</span>
        </div>
        <div class="plugin-footer">
          <div class="plugin-dl-links">
