---
import { plugins } from '../data/plugins.js';
import { team }    from '../data/team.js';
import { servers } from '../data/servers.js';
import { community } from '../data/community.js';
import { promo }   from '../data/promo.js';
const serversLoop = [...servers, ...servers];
---
<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Blakube Docs</title>
<meta name="description" content="High-performance Minecraft plugins built for Paper servers.">
<link rel="icon" href="/brand/BLAKUBE_ICON.png">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<style>
/* ... (Tus estilos CSS se mantienen exactamente igual) ... */
:root{
  --blue:#2B7FFF;--blue-dim:#1a5fd4;--blue-subtle:rgba(43,127,255,0.08);
  --accent:#00d4ff;--font:'Poppins',sans-serif;
  --radius-card:16px;--radius-md:10px;--radius-sm:8px;
}
[data-theme="dark"]{
  --bg:#080c14;--surface:#0f1624;--surface2:#141c2e;
  --border:rgba(43,127,255,0.2);--border-dim:rgba(255,255,255,0.07);
  --text:#e8edf5;--muted:#6b7a99;
  --nav-bg:rgba(8,12,20,0.9);--grid-color:rgba(43,127,255,0.03);
  --card-shadow:0 4px 24px rgba(0,0,0,0.35);
  --card-shadow-hover:0 8px 32px rgba(43,127,255,0.10);
}
[data-theme="light"]{
  --bg:#f0f2f8;--surface:#ffffff;--surface2:#e8ecf5;
  --border:rgba(43,127,255,0.2);--border-dim:rgba(0,0,0,0.07);
  --text:#0d1321;--muted:#5a6a8a;
  --nav-bg:rgba(240,242,248,0.92);--grid-color:rgba(43,127,255,0.035);
  --card-shadow:0 2px 16px rgba(0,0,0,0.07);
  --card-shadow-hover:0 6px 28px rgba(43,127,255,0.13);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html,body{background:var(--bg);color:var(--text);font-family:var(--font);min-height:100vh;overflow-x:hidden;transition:background .3s,color .3s;}
body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(var(--grid-color) 1px,transparent 1px),linear-gradient(90deg,var(--grid-color) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;}
a,button,[role=button],.plugin-card,.team-card,.carousel-item{cursor:pointer;}
img{cursor:default;}
.wrap{max-width:1100px;margin:0 auto;padding:0 2rem;position:relative;z-index:1;}
.theme-toggle{display:flex;align-items:center;gap:2px;background:var(--surface2);border:1px solid var(--border-dim);border-radius:var(--radius-sm);padding:3px;}
.theme-btn{width:28px;height:28px;border-radius:6px;border:none;background:transparent;color:var(--muted);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:13px;transition:all .15s;font-family:var(--font);}
.theme-btn.active{background:var(--blue);color:#fff;}
.theme-btn:hover:not(.active){background:var(--border-dim);color:var(--text);}
nav{position:sticky;top:0;z-index:100;background:var(--nav-bg);backdrop-filter:blur(16px);border-bottom:1px solid var(--border-dim);padding:.85rem 0;transition:background .3s;}
.nav-inner{display:flex;align-items:center;justify-content:space-between;gap:1rem;}
.nav-logo{text-decoration:none;display:flex;align-items:center;}
.nav-logo img{height:36px;display:block;}
.nav-links{display:flex;gap:2rem;list-style:none;flex:1;justify-content:center;}
.nav-links a{color:var(--muted);text-decoration:none;font-size:.82rem;font-weight:500;transition:color .2s;}
.nav-links a:hover{color:var(--blue);}
.nav-right{display:flex;align-items:center;gap:.6rem;}
.nav-icon{width:34px;height:34px;border-radius:var(--radius-sm);border:1px solid var(--border-dim);background:transparent;display:flex;align-items:center;justify-content:center;color:var(--muted);text-decoration:none;transition:all .2s;font-size:16px;}
.nav-icon:hover{border-color:var(--border);color:var(--blue);}
.hero{position:relative;min-height:560px;display:flex;align-items:center;justify-content:center;text-align:center;overflow:hidden;padding:5rem 0;}
.hero-bg{position:absolute;inset:0;z-index:0;background:url('/brand/hero-bg.jpg') center/cover no-repeat;filter:brightness(.25);}
[data-theme="light"] .hero-bg{filter:brightness(.35);}
.hero-bg-overlay{position:absolute;inset:0;z-index:1;background:linear-gradient(to bottom,rgba(8,12,20,.1) 0%,rgba(8,12,20,.75) 100%);}
[data-theme="light"] .hero-bg-overlay{background:linear-gradient(to bottom,rgba(240,242,248,.1) 0%,rgba(240,242,248,.6) 100%);}
.hero-content{position:relative;z-index:2;max-width:700px;padding:0 1rem;}
.hero h1{font-size:clamp(2rem,5vw,3.5rem);font-weight:800;line-height:1.1;margin-bottom:1.25rem;color:#fff;letter-spacing:-.5px;}
[data-theme="light"] .hero h1{color:var(--text);}
.hero h1 span{color:var(--blue);}
.hero p{font-size:1rem;color:rgba(255,255,255,.65);line-height:1.8;margin-bottom:2.5rem;font-weight:300;}
[data-theme="light"] .hero p{color:var(--muted);}
.hero-btns{display:flex;gap:.75rem;justify-content:center;flex-wrap:wrap;}
.btn{display:inline-flex;align-items:center;gap:8px;padding:.7rem 1.5rem;border-radius:var(--radius-sm);font-weight:600;font-size:.85rem;text-decoration:none;transition:all .2s;cursor:pointer;border:none;font-family:var(--font);}
.btn-primary{background:var(--blue);color:#fff;}
.btn-primary:hover{background:var(--blue-dim);transform:translateY(-1px);}
.btn-ghost{background:rgba(255,255,255,.1);color:#fff;border:1px solid rgba(255,255,255,.2);}
[data-theme="light"] .btn-ghost{background:var(--surface2);color:var(--text);border-color:var(--border-dim);}
.btn-ghost:hover{background:rgba(255,255,255,.18);}
[data-theme="light"] .btn-ghost:hover{background:var(--border-dim);}
.section{padding:4rem 0;}
.section-label{font-size:.7rem;font-weight:600;text-transform:uppercase;letter-spacing:2px;color:var(--blue);margin-bottom:.6rem;}
.section-title{font-size:clamp(1.5rem,3vw,2.2rem);font-weight:800;color:var(--text);margin-bottom:.4rem;letter-spacing:-.3px;}
.section-sub{color:var(--muted);font-size:.9rem;margin-bottom:2.5rem;max-width:480px;line-height:1.7;}
.promo-section{padding:2.5rem 0;}
.promo-banner{border-radius:var(--radius-card);overflow:hidden;position:relative;border:1px solid var(--border);box-shadow:var(--card-shadow);}
.promo-bg{position:absolute;inset:0;background-size:cover;background-position:center;opacity:.18;}
.promo-gradient{position:absolute;inset:0;}
.promo-inner{position:relative;z-index:1;display:flex;align-items:center;gap:2rem;padding:1.75rem 2rem;flex-wrap:wrap;}
.promo-left{display:flex;align-items:center;gap:1.25rem;flex:1;min-width:200px;}
.promo-logo{width:64px;height:64px;border-radius:12px;overflow:hidden;flex-shrink:0;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.15);}
.promo-logo img{width:100%;height:100%;object-fit:cover;}
.promo-text{flex:1;}
.promo-title{font-size:1.1rem;font-weight:800;color:#fff;margin-bottom:.25rem;}
.promo-desc{font-size:.82rem;color:rgba(255,255,255,.7);line-height:1.6;max-width:420px;}
.promo-right{display:flex;align-items:center;gap:1rem;flex-wrap:wrap;}
.promo-price-block{text-align:right;}
.promo-original{font-size:.75rem;color:rgba(255,255,255,.5);text-decoration:line-through;}
.promo-discount{font-size:.65rem;font-weight:700;color:#fbbf24;text-transform:uppercase;letter-spacing:.5px;}
.promo-price{font-size:1.5rem;font-weight:800;color:#fff;}
.promo-buttons{display:flex;gap:.6rem;flex-wrap:wrap;}
.promo-btn-primary{display:inline-flex;align-items:center;gap:6px;padding:.6rem 1.25rem;border-radius:var(--radius-sm);background:#fff;color:#0d1321;font-weight:700;font-size:.82rem;text-decoration:none;transition:all .2s;border:none;font-family:var(--font);}
.promo-btn-primary:hover{background:#e8ecf5;transform:translateY(-1px);}
.promo-btn-ghost{display:inline-flex;align-items:center;gap:6px;padding:.6rem 1.25rem;border-radius:var(--radius-sm);background:rgba(255,255,255,.12);color:#fff;font-weight:600;font-size:.82rem;text-decoration:none;transition:all .2s;border:1px solid rgba(255,255,255,.2);font-family:var(--font);}
.promo-btn-ghost:hover{background:rgba(255,255,255,.2);}
.plugin-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:1.25rem;}
.plugin-card{background:var(--surface);border:1px solid var(--border-dim);border-radius:var(--radius-card);overflow:hidden;transition:border-color .2s,transform .2s,box-shadow .2s;display:flex;flex-direction:column;box-shadow:var(--card-shadow);position:relative;}
.plugin-card:hover{border-color:var(--border);transform:translateY(-3px);box-shadow:var(--card-shadow-hover);}
.featured-badge{position:absolute;top:12px;right:12px;z-index:10;background:var(--blue);color:#fff;font-size:.62rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;padding:4px 10px;border-radius:100px;display:flex;align-items:center;gap:4px;}
.discount-ribbon{position:absolute;top:12px;left:12px;z-index:10;background:#ef4444;color:#fff;font-size:.62rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;padding:4px 10px;border-radius:100px;display:flex;align-items:center;gap:4px;}
.plugin-banner{width:100%;height:130px;background:var(--surface2);position:relative;overflow:hidden;flex-shrink:0;background-size:cover;background-position:center;}
.plugin-banner::after{content:'';position:absolute;inset:0;background:linear-gradient(to bottom,transparent 40%,var(--surface) 100%);}
.plugin-body{padding:0 1.5rem 1.5rem;display:flex;flex-direction:column;flex:1;}
.plugin-header{display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;margin-top:-1rem;margin-bottom:1rem;position:relative;z-index:1;}
.plugin-logo{width:56px;height:56px;border-radius:12px;background:var(--surface2);border:2px solid var(--border-dim);display:flex;align-items:center;justify-content:center;flex-shrink:0;overflow:hidden;}
.plugin-logo img{width:100%;height:100%;object-fit:cover;border-radius:10px;}
.plugin-price{background:var(--surface2);border:1px solid var(--border-dim);border-radius:var(--radius-md);padding:.4rem .8rem;text-align:right;margin-top:1rem;}
.plugin-price-label{font-size:.62rem;color:var(--muted);text-transform:uppercase;letter-spacing:1px;font-weight:600;}
.plugin-price-original{font-size:.72rem;color:var(--muted);text-decoration:line-through;margin-bottom:1px;}
.plugin-price-discount{font-size:.62rem;font-weight:700;color:#ef4444;letter-spacing:.5px;}
.plugin-price-val{font-size:1.1rem;font-weight:800;color:var(--text);line-height:1;}
.plugin-price-val.free{color:#22c55e;}
.plugin-name{font-size:1.1rem;font-weight:700;color:var(--text);margin-bottom:.4rem;}
.plugin-desc{font-size:.82rem;color:var(--muted);line-height:1.7;margin-bottom:1rem;flex:1;}
.plugin-tags{display:flex;gap:5px;flex-wrap:wrap;margin-bottom:1.25rem;}
.tag{font-size:.62rem;font-weight:600;text-transform:uppercase;letter-spacing:.5px;padding:3px 8px;border-radius:4px;background:var(--blue-subtle);color:var(--blue);border:1px solid var(--border);}
.plugin-footer{border-top:1px solid var(--border-dim);padding-top:1rem;display:flex;align-items:center;justify-content:space-between;gap:.5rem;flex-wrap:wrap;}
.plugin-dl-links{display:flex;gap:.4rem;flex-wrap:wrap;}
.dl-btn{display:inline-flex;align-items:center;gap:5px;padding:5px 10px;border-radius:6px;font-size:.72rem;font-weight:600;text-decoration:none;border:1px solid var(--border-dim);background:var(--surface2);color:var(--muted);transition:all .2s;font-family:var(--font);}
.dl-btn:hover{border-color:var(--border);color:var(--blue);}
.plugin-doc-link{font-size:.75rem;font-weight:600;color:var(--blue);text-decoration:none;white-space:nowrap;display:flex;align-items:center;gap:4px;transition:color .2s;}
.plugin-doc-link:hover{color:var(--accent);}
.social-grid{display:flex;gap:.75rem;flex-wrap:wrap;margin-top:2rem;}
.social-btn{display:inline-flex;align-items:center;gap:8px;padding:.6rem 1.2rem;border-radius:var(--radius-md);font-size:.82rem;font-weight:500;text-decoration:none;border:1px solid var(--border-dim);background:var(--surface);color:var(--text);transition:all .2s;cursor:pointer;font-family:var(--font);box-shadow:var(--card-shadow);}
.social-btn:hover{border-color:var(--border);color:var(--blue);}
.copy-ok{font-size:.72rem;color:var(--accent);opacity:0;transition:opacity .3s;margin-left:2px;}
.copy-ok.show{opacity:1;}
.carousel-wrap{overflow:hidden;position:relative;padding:.5rem 0;}
.carousel-track{display:flex;gap:1.25rem;align-items:center;animation:scroll 30s linear infinite;width:max-content;}
.carousel-wrap:hover .carousel-track{animation-play-state:paused;}
@keyframes scroll{0%{transform:translateX(0);}100%{transform:translateX(-50%);}}
.carousel-item{flex-shrink:0;height:60px;min-width:120px;display:flex;align-items:center;justify-content:center;padding:0 1.25rem;background:var(--surface);border:1px solid var(--border-dim);border-radius:12px;transition:all .2s;filter:grayscale(1) opacity(.45);box-shadow:var(--card-shadow);}
.carousel-item:hover{filter:grayscale(0) opacity(1);border-color:var(--border);}
.carousel-item img{max-height:36px;max-width:100px;width:auto;object-fit:contain;display:block;}
.carousel-fade-l,.carousel-fade-r{position:absolute;top:0;bottom:0;width:100px;z-index:2;pointer-events:none;}
.carousel-fade-l{left:0;background:linear-gradient(to right,var(--bg),transparent);}
.carousel-fade-r{right:0;background:linear-gradient(to left,var(--bg),transparent);}
.team-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(210px,1fr));gap:1.25rem;}
.team-card{background:var(--surface);border:1px solid var(--border-dim);border-radius:var(--radius-card);overflow:hidden;transition:border-color .2s,transform .2s,box-shadow .2s;box-shadow:var(--card-shadow);}
.team-card:hover{border-color:var(--border);transform:translateY(-2px);box-shadow:var(--card-shadow-hover);}
.team-banner{height:80px;width:100%;background-size:cover;background-position:center;}
.avatar-wrap{display:flex;justify-content:center;margin-top:-28px;margin-bottom:.75rem;}
.avatar{width:56px;height:56px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1rem;font-weight:700;color:#fff;border:3px solid var(--surface);position:relative;z-index:1;overflow:hidden;flex-shrink:0;}
.avatar img.avatar-img{width:100%;height:100%;object-fit:cover;border-radius:50%;position:absolute;inset:0;opacity:0;transition:opacity .3s;}
.avatar img.avatar-img.loaded{opacity:1;}
.avatar-fallback{position:relative;z-index:0;}
.avatar:has(.avatar-img.loaded) .avatar-fallback{display:none;}
.team-body{padding:0 1.25rem 1.25rem;text-align:center;}
.member-name{font-size:.95rem;font-weight:700;color:var(--text);margin-bottom:.25rem;}
.member-role{display:inline-block;font-size:.65rem;font-weight:600;text-transform:uppercase;letter-spacing:1px;padding:2px 10px;border-radius:100px;margin-bottom:1rem;}
.member-icons{display:flex;justify-content:center;gap:.5rem;flex-wrap:wrap;}
.icon-link{width:30px;height:30px;border-radius:var(--radius-sm);border:1px solid var(--border-dim);background:transparent;display:flex;align-items:center;justify-content:center;color:var(--muted);text-decoration:none;transition:all .2s;cursor:pointer;font-family:var(--font);font-size:14px;}
.icon-link:hover{border-color:var(--border);color:var(--blue);}
footer{border-top:1px solid var(--border-dim);padding:3rem 0 5rem;margin-top:2rem;}
.footer-inner{display:grid;grid-template-columns:1.5fr repeat(2,1fr);gap:2rem;margin-bottom:2.5rem;}
.footer-brand{display:flex;flex-direction:column;gap:.75rem;}
.footer-logo{font-size:1.1rem;font-weight:800;color:var(--blue);letter-spacing:1px;}
.footer-tagline{font-size:.8rem;color:var(--muted);line-height:1.6;max-width:220px;}
.footer-social{display:flex;gap:.5rem;flex-wrap:wrap;margin-top:.25rem;}
.footer-col h4{font-size:.72rem;font-weight:600;text-transform:uppercase;letter-spacing:1.5px;color:var(--muted);margin-bottom:1rem;}
.footer-col ul{list-style:none;display:flex;flex-direction:column;gap:.5rem;}
.footer-col a{font-size:.82rem;color:var(--muted);text-decoration:none;transition:color .2s;display:inline-flex;align-items:center;gap:6px;}
.footer-col a:hover{color:var(--text);}
.footer-badge{font-size:.58rem;background:var(--blue);color:#fff;padding:1px 6px;border-radius:100px;font-weight:700;vertical-align:middle;}
.footer-badge.sale{background:#ef4444;}
.footer-bottom{border-top:1px solid var(--border-dim);padding-top:1.5rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;}
.footer-copy{font-size:.75rem;color:var(--muted);}
.footer-copy span{color:var(--blue);font-weight:600;}
.footer-legal{display:flex;gap:1.5rem;}
.footer-legal a{font-size:.75rem;color:var(--muted);text-decoration:none;transition:color .2s;cursor:pointer;}
.footer-legal a:hover{color:var(--text);}
.scroll-top{position:fixed;bottom:2rem;right:2rem;width:42px;height:42px;border-radius:50%;background:var(--blue);color:#fff;border:none;display:flex;align-items:center;justify-content:center;font-size:18px;cursor:pointer;z-index:99;opacity:0;transform:translateY(10px);transition:opacity .3s,transform .3s,background .2s;box-shadow:0 4px 16px rgba(43,127,255,.35);}
.scroll-top.visible{opacity:1;transform:translateY(0);}
.scroll-top:hover{background:var(--blue-dim);}
@media(max-width:768px){
  .nav-links{display:none;}
  .footer-inner{grid-template-columns:1fr 1fr;}
  .footer-brand{grid-column:1/-1;}
  .plugin-grid{grid-template-columns:1fr;}
  .team-grid{grid-template-columns:repeat(auto-fit,minmax(160px,1fr));}
  .hero h1{font-size:2rem;}
  .section{padding:2.5rem 0;}
  .promo-inner{flex-direction:column;gap:1rem;}
  .promo-right{width:100%;justify-content:space-between;}
}
@media(max-width:480px){
  .wrap{padding:0 1rem;}
  .hero{min-height:420px;padding:3rem 0;}
  .footer-inner{grid-template-columns:1fr;}
  .social-btn{font-size:.78rem;padding:.5rem .9rem;}
}
</style>
</head>
<body>

<nav>
  <div class="wrap nav-inner">
    <a href="/" class="nav-logo"><img src="/brand/BLAKUBE_ICON.png" alt="Blakube"></a>
    <ul class="nav-links">
      <li><a href="#plugins">Plugins</a></li>
      <li><a href="/bk-tops/introduction/">Docs</a></li>
      <li><a href="#team">Team</a></li>
      <li><a href="#community">Community</a></li>
    </ul>
    <div class="nav-right">
      <div class="theme-toggle">
        <button class="theme-btn" id="btn-light" onclick="setTheme('light')" title="Light"><i class="bi bi-sun"></i></button>
        <button class="theme-btn" id="btn-auto"  onclick="setTheme('auto')"  title="Auto"><i class="bi bi-circle-half"></i></button>
        <button class="theme-btn" id="btn-dark"  onclick="setTheme('dark')"  title="Dark"><i class="bi bi-moon"></i></button>
      </div>
      <a href="https://github.com/Blakube/" target="_blank" class="nav-icon" title="GitHub"><i class="bi bi-github"></i></a>
      <a href="https://discord.blakube.com/" target="_blank" class="nav-icon" title="Discord"><i class="bi bi-discord"></i></a>
    </div>
  </div>
</nav>

<section class="hero">
  <div class="hero-bg"></div>
  <div class="hero-bg-overlay"></div>
  <div class="hero-content">
    <h1>Your server deserves<br><span>the best tools</span></h1>
    <p>At Blakube Design, we craft high-performance plugins built for Paper servers. Explore our documentation and get everything running in minutes.</p>
    <div class="hero-btns">
      <a href="#plugins" class="btn btn-primary"><i class="bi bi-grid-fill"></i>Explore plugins</a>
      <a href="https://discord.blakube.com/" target="_blank" class="btn btn-ghost"><i class="bi bi-discord"></i>Join Discord</a>
    </div>
  </div>
</section>

<div class="wrap">

<!-- 1. PROMO BANNER (Movido arriba de Plugins) -->
{promo.enabled && (
  <section class="promo-section">
    <div class="promo-banner">
      {promo.banner && <div class="promo-bg" style={`background-image:url('${promo.banner}');`}></div>}
      <div class="promo-gradient" id="promoBg"></div>
      <div class="promo-inner">
        <div class="promo-left">
          {promo.logo && (
            <div class="promo-logo"><img src={promo.logo} alt={promo.title} /></div>
          )}
          <div class="promo-text">
            <div class="promo-title">{promo.title}</div>
            <div class="promo-desc">{promo.description}</div>
          </div>
        </div>
        <div class="promo-right">
          {promo.price && (
            <div class="promo-price-block">
              {promo.originalPrice && <div class="promo-original">{promo.originalPrice}</div>}
              {promo.discount && <div class="promo-discount">{promo.discount}</div>}
              <div class="promo-price">{promo.price}</div>
            </div>
          )}
          <div class="promo-buttons">
            {promo.buttons.map((btn) => (
              btn.primary
                ? <a href={btn.href} target="_blank" class="promo-btn-primary"><i class="bi bi-bag-fill"></i>{btn.label}</a>
                : <a href={btn.href} class="promo-btn-ghost"><i class="bi bi-book"></i>{btn.label}</a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>
)}

