<script is:inline>
// ── THEME SYSTEM ──
function getStoredTheme() { return localStorage.getItem('bk-theme') || 'auto'; }
function applyTheme(t) {
  const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
  const resolved = t === 'auto' ? (prefersDark ? 'dark' : 'light') : t;
  document.documentElement.setAttribute('data-theme', resolved);
  ['light','auto','dark'].forEach(id => {
    document.getElementById('btn-' + id)?.classList.toggle('active', id === t);
  });
}
function setTheme(t) { localStorage.setItem('bk-theme', t); applyTheme(t); }
applyTheme(getStoredTheme());
window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
  if (getStoredTheme() === 'auto') applyTheme('auto');
});

// ── COPY HELPERS ──
function copyDiscord() {
  navigator.clipboard.writeText('blakubedesign').then(() => {
    const el = document.getElementById('cf');
    el.classList.add('show');
    setTimeout(() => el.classList.remove('show'), 2000);
  });
}
function copyUser(btn, user) {
  navigator.clipboard.writeText(user).then(() => {
    btn.style.color = 'var(--accent)'; btn.style.borderColor = 'var(--accent)';
    setTimeout(() => { btn.style.color = ''; btn.style.borderColor = ''; }, 1500);
  });
}
</script>
