<script is:inline>
  // --- 1. LÓGICA DE TEMA (CORREGIDA) ---
  window.applyTheme = function(t) {
    const isDarkSystem = window.matchMedia('(prefers-color-scheme: dark)').matches;
    const themeToApply = t === 'auto' ? (isDarkSystem ? 'dark' : 'light') : t;
    document.documentElement.setAttribute('data-theme', themeToApply);
    
    ['light', 'auto', 'dark'].forEach(id => {
      const btn = document.getElementById('btn-' + id);
      if (btn) btn.classList.toggle('active', id === t);
    });

    const pg = document.getElementById('promoBg');
    if (pg) pg.style.opacity = themeToApply === 'dark' ? '0.8' : '0.4';
  };

  window.setTheme = function(t) {
    localStorage.setItem('bk-theme', t);
    window.applyTheme(t);
  };

  // Inicialización rápida
  window.applyTheme(localStorage.getItem('bk-theme') || 'auto');

  // --- 2. AVATARES ---
  document.querySelectorAll('.avatar-img').forEach(img => {
    const onLoad = () => img.classList.add('loaded');
    if (img.complete) onLoad();
    else img.addEventListener('load', onLoad);
  });

  // --- 3. SCROLL TO TOP ---
  const scrollBtn = document.getElementById('scrollTop');
  window.addEventListener('scroll', () => scrollBtn?.classList.toggle('visible', window.scrollY > 400));

  // --- 4. COPIAR TEXTO ---
  window.copyText = function(text, feedbackId) {
    navigator.clipboard.writeText(text).then(() => {
      const el = document.getElementById(feedbackId);
      if (el) {
        el.classList.add('show');
        setTimeout(() => el.classList.remove('show'), 2000);
      }
    });
  };

  // Soporte para navegación de Astro
  document.addEventListener('astro:after-swap', () => window.applyTheme(localStorage.getItem('bk-theme') || 'auto'));
</script>
</body>
